refs/
node_modules/
dist/
release-bin/
# Ignore kobe's runtime state under .kobe/ but keep the committed per-repo
# init convention files (`kobe repo` / state/repo-init.ts) — they're meant
# to be version-controlled. Same `/*` + `!` pattern as `.claude/` below.
.kobe/*
!.kobe/init.sh
!.kobe/init-prompt.md
# Ignore everything under .claude/ except the project-scoped skills
# directory — those need to live in the repo so Claude Code users
# pick them up automatically. (Trailing `/*` instead of `/` lets the
# `!` negation re-include selected children; a bare `.claude/`
# would block all children regardless of later negations.)
.claude/*
!.claude/skills/
!.claude/skills/**
# Agent skills installed by `npx skills add` — `.claude/skills/<name>`
# is a symlink into `.agents/skills/<name>`, so the real files must
# also live in the repo for the symlinks to resolve on teammate clones.
!.agents/
!.agents/**
tsconfig.vitest-temp.json
.DS_Store
*.log
.env
.env.local

# Brand Studio scratch output is local-only. Accepted assets live under
# public/brand/ and are committed.
.harness/brand-studio/out/

# brand/render outputs rendered assets into public/brand/ (committed).
# Local-only build artefacts inside the render package itself
# (Remotion's `out/`, etc.) are ignored via brand/render/.gitignore.

# autonomous-skill per-sprint worktrees + session state
.worktrees/
.autonomous/

# Personal/local-only skill installs that shouldn't be checked in.
# (Other .claude/skills/ entries are committed via the !.claude/skills/
# rule above; this list overrides them back to ignored.)
.claude/skills/handoff/

# Per-package .claude/ directories — agent-run worktrees and other
# runtime artefacts. Root .claude/ is already covered above; this
# catches the same shape one level deeper.
packages/*/.claude/

# `bun run dev:test` mock environment — seeded by scripts/dev-fixture.ts,
# contains throwaway git repos + ~/.kobe/~/.claude state.
packages/*/.dev-fixture/

# `bun run dev:sandbox` — isolated REAL-engine environment (real
# claude / codex subprocesses, but their tasks.json + daemon socket +
# worktrees live under here instead of $HOME). Wipe with
# `bun run dev:sandbox:reset`.
packages/*/.dev-sandbox/

# Session handoff — local working state / scratchpad for the next agent in
# THIS environment. Not shared history (the durable record lives in git
# commits, CHANGELOG.md, docs/, and docs/issues.json). Keep it local.
HANDOFF.md
.gstack/
/.env
/outputs/
/published/
/releases/
