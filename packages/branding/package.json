{
  "name": "kobe-branding",
  "version": "0.0.0",
  "private": true,
  "description": "Animated logo concepts for kobe (Remotion). Source lives here; rendered outputs land in ../../docs/assets/brand/ and are committed.",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "still:bracket": "remotion still src/index.ts bracket-chip ../../docs/assets/brand/bracket-chip.png --frame=80",
    "still:grid": "remotion still src/index.ts pane-grid ../../docs/assets/brand/pane-grid.png --frame=120",
    "still:streams": "remotion still src/index.ts task-streams ../../docs/assets/brand/task-streams.png --frame=85",
    "still:glyph": "remotion still src/index.ts glyph-k ../../docs/assets/brand/glyph-k.png --frame=80",
    "gif:bracket": "remotion render src/index.ts bracket-chip ../../docs/assets/brand/bracket-chip.gif --codec=gif",
    "gif:grid": "remotion render src/index.ts pane-grid ../../docs/assets/brand/pane-grid.gif --codec=gif",
    "gif:streams": "remotion render src/index.ts task-streams ../../docs/assets/brand/task-streams.gif --codec=gif",
    "gif:glyph": "remotion render src/index.ts glyph-k ../../docs/assets/brand/glyph-k.gif --codec=gif --width=400 --every-nth-frame=2",
    "mp4:bracket": "remotion render src/index.ts bracket-chip ../../docs/assets/brand/bracket-chip.mp4",
    "mp4:grid": "remotion render src/index.ts pane-grid ../../docs/assets/brand/pane-grid.mp4",
    "mp4:streams": "remotion render src/index.ts task-streams ../../docs/assets/brand/task-streams.mp4",
    "mp4:glyph": "remotion render src/index.ts glyph-k ../../docs/assets/brand/glyph-k.mp4",
    "still:boot": "remotion still src/index.ts tui-boot ../../docs/assets/brand/tui-boot.png --frame=160",
    "still:worktree": "remotion still src/index.ts worktree-fork ../../docs/assets/brand/worktree-fork.png --frame=175",
    "still:sessions": "remotion still src/index.ts session-grid ../../docs/assets/brand/session-grid.png --frame=140",
    "gif:boot": "remotion render src/index.ts tui-boot ../../docs/assets/brand/tui-boot.gif --codec=gif --every-nth-frame=2",
    "gif:worktree": "remotion render src/index.ts worktree-fork ../../docs/assets/brand/worktree-fork.gif --codec=gif --every-nth-frame=2",
    "gif:sessions": "remotion render src/index.ts session-grid ../../docs/assets/brand/session-grid.gif --codec=gif --every-nth-frame=2",
    "mp4:boot": "remotion render src/index.ts tui-boot ../../docs/assets/brand/tui-boot.mp4",
    "mp4:worktree": "remotion render src/index.ts worktree-fork ../../docs/assets/brand/worktree-fork.mp4",
    "mp4:sessions": "remotion render src/index.ts session-grid ../../docs/assets/brand/session-grid.mp4",
    "stills:all": "bun run still:bracket && bun run still:grid && bun run still:streams && bun run still:glyph && bun run still:boot && bun run still:worktree && bun run still:sessions",
    "gifs:all": "bun run gif:bracket && bun run gif:grid && bun run gif:streams && bun run gif:glyph && bun run gif:boot && bun run gif:worktree && bun run gif:sessions",
    "render:all": "mkdir -p ../../docs/assets/brand && bun run stills:all && bun run gifs:all"
  },
  "dependencies": {
    "@remotion/cli": "4.0.380",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.380"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "typescript": "5.8.2"
  }
}
