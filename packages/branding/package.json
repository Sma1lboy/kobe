{
  "name": "kobe-branding",
  "version": "0.0.0",
  "private": true,
  "description": "Animated logo concepts for kobe (Remotion). Source lives here; rendered outputs land in ../../public/brand/ and are committed.",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "still:bracket": "remotion still src/index.ts bracket-chip ../../public/brand/bracket-chip.png --frame=80",
    "still:grid": "remotion still src/index.ts pane-grid ../../public/brand/pane-grid.png --frame=120",
    "still:streams": "remotion still src/index.ts task-streams ../../public/brand/task-streams.png --frame=85",
    "still:glyph": "remotion still src/index.ts glyph-k ../../public/brand/glyph-k.png --frame=80",
    "gif:bracket": "remotion render src/index.ts bracket-chip ../../public/brand/bracket-chip.gif --codec=gif",
    "gif:grid": "remotion render src/index.ts pane-grid ../../public/brand/pane-grid.gif --codec=gif",
    "gif:streams": "remotion render src/index.ts task-streams ../../public/brand/task-streams.gif --codec=gif",
    "gif:glyph": "remotion render src/index.ts glyph-k ../../public/brand/glyph-k.gif --codec=gif --width=400 --every-nth-frame=2",
    "mp4:bracket": "remotion render src/index.ts bracket-chip ../../public/brand/bracket-chip.mp4",
    "mp4:grid": "remotion render src/index.ts pane-grid ../../public/brand/pane-grid.mp4",
    "mp4:streams": "remotion render src/index.ts task-streams ../../public/brand/task-streams.mp4",
    "mp4:glyph": "remotion render src/index.ts glyph-k ../../public/brand/glyph-k.mp4",
    "stills:all": "bun run still:bracket && bun run still:grid && bun run still:streams && bun run still:glyph",
    "gifs:all": "bun run gif:bracket && bun run gif:grid && bun run gif:streams && bun run gif:glyph",
    "render:all": "mkdir -p ../../public/brand && bun run stills:all && bun run gifs:all"
  },
  "dependencies": {
    "@remotion/cli": "4.0.482",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.482"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "typescript": "5.8.2"
  }
}
