{
  "id": "quicklook-replay",
  "viewport": {
    "cols": 160,
    "rows": 45,
    "width": 1280,
    "height": 720
  },
  "capture": {
    "fps": 10,
    "seconds": 50,
    "output": "src/quicklook/frames.json",
    "home": ".capture-home-puretui",
    "repoDefault": "fixture-repo",
    "shellPrompt": ""
  },
  "setup": {
    "readyWait": "workspaceReady",
    "seedTasks": [
      {
        "title": "fix flaky turn-detector test",
        "status": "in_progress"
      }
    ]
  },
  "waits": {
    "workspaceReady": {
      "pattern": "KOBE",
      "timeoutMs": 15000
    },
    "newTaskDialog": {
      "pattern": "New task",
      "timeoutMs": 8000
    },
    "claudeComposerReady": {
      "pattern": "❯",
      "timeoutMs": 20000
    },
    "claudePermissionPrompt": {
      "pattern": "Do you want to proceed?",
      "timeoutMs": 30000
    }
  },
  "text": {
    "claudePrompt": "Run this exact shell command once: printf replay-color-probe > replay-color-probe.txt"
  },
  "flows": {
    "createTask": {
      "openKey": "n",
      "dialogWait": "newTaskDialog",
      "dialogSettleMs": 1500,
      "tabCount": 4,
      "tabDelayMs": 700,
      "submitKey": "Enter"
    }
  },
  "beats": [
    {
      "at": 3,
      "action": "flow",
      "flow": "createTask",
      "engine": "claude"
    },
    {
      "at": 11,
      "action": "typeTextWhenReady",
      "waitFor": "claudeComposerReady",
      "textRef": "claudePrompt",
      "msPerChar": 45,
      "settleMs": 500,
      "submit": true,
      "submitDelayMs": 500
    },
    {
      "at": 28,
      "action": "waitFor",
      "waitFor": "claudePermissionPrompt"
    },
    {
      "at": 28,
      "action": "sleep",
      "ms": 2500
    }
  ],
  "regions": {
    "chat": {
      "c0": 33,
      "c1": 125,
      "r0": 1,
      "r1": 43,
      "hash": "rg_1ctg642"
    },
    "agent": {
      "c0": 33,
      "c1": 125,
      "r0": 1,
      "r1": 43,
      "hash": "rg_1xlx0jz"
    },
    "dialog": {
      "c0": 30,
      "c1": 130,
      "r0": 6,
      "r1": 38,
      "hash": "rg_01xmnv4"
    },
    "input": {
      "c0": 33,
      "c1": 125,
      "r0": 1,
      "r1": 43,
      "hash": "rg_0uquako"
    }
  },
  "stages": [
    {
      "name": "boot",
      "from": 0,
      "to": 3
    },
    {
      "name": "dialog",
      "from": 3,
      "to": 8,
      "region": "dialog"
    },
    {
      "name": "engine-boot",
      "from": 8,
      "to": 14
    },
    {
      "name": "type-prompt",
      "from": 14,
      "to": 21,
      "region": "input"
    },
    {
      "name": "agent",
      "from": 21,
      "to": "capture-end"
    },
    {
      "name": "wrap",
      "from": "capture-end",
      "to": "end"
    }
  ],
  "camera": {
    "transitionSeconds": 1.2,
    "fit": 0.8,
    "minScale": 1,
    "maxScale": 1.6,
    "tailHoldSeconds": 4,
    "minChangedCells": 10,
    "rowGap": 3,
    "colQuantiles": [0.05, 0.95]
  },
  "theme": {
    "defaultFg": "#FFFFFF",
    "defaultBg": "#141413",
    "ansi16": [
      "#141413",
      "#D47563",
      "#9ACA86",
      "#E8C96B",
      "#CC785C",
      "#9B87F5",
      "#D4967E",
      "#EAE7DF",
      "#3A3835",
      "#E08A76",
      "#B0DCA0",
      "#F2DA8C",
      "#D4967E",
      "#B3A3F8",
      "#E2B39F",
      "#FFFFFF"
    ]
  },
  "delivery": {
    "speedCuts": [1, 4],
    "posterAt": 3.2
  }
}
