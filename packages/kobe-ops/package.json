{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sma1lboy/kobe-ops",
  "version": "0.6.0",
  "description": "kobe Ops pane — file watcher + ops menu that lives inside a kobe-managed tmux session next to claude.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "kobe-ops": "src/cli/index.ts"
  },
  "files": ["src", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sma1lboy/kobe.git",
    "directory": "packages/kobe-ops"
  },
  "homepage": "https://github.com/Sma1lboy/kobe/tree/main/packages/kobe-ops#readme",
  "bugs": {
    "url": "https://github.com/Sma1lboy/kobe/issues"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check ."
  },
  "dependencies": {
    "@opentui/core": "0.2.4",
    "@opentui/solid": "0.2.4",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.12",
    "typescript": "5.8.2",
    "vitest": "2.1.9"
  }
}
