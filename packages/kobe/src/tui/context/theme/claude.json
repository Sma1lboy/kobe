    "darkAccentHover": "#E0AB96",
    "darkRed": "#D47563",
    "darkOrange": "#D97757",
    "darkYellow": "#E8C96B",
    "darkGreen": "#9ACA86",
    "darkBlue": "#61AAF2",
    "darkViolet": "#9B87F5",
    "darkTerracotta": "#BF4D43",
    "lightBg": "#FAF9F5",
